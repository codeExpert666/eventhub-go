EVENTHUB_APP_NAME=eventhub-backend
EVENTHUB_ENV=dev
EVENTHUB_HTTP_PORT=8080
EVENTHUB_VERSION=dev
EVENTHUB_LOG_LEVEL=DEBUG
OPENAPI_ENABLED=true
EVENTHUB_MYSQL_DSN=eventhub:eventhub@tcp(localhost:3306)/eventhub?charset=utf8mb4&parseTime=true&loc=Local
EVENTHUB_MYSQL_MAX_OPEN_CONNS=10
EVENTHUB_MYSQL_MAX_IDLE_CONNS=2
EVENTHUB_MYSQL_CONN_MAX_LIFETIME=30m
EVENTHUB_MYSQL_CONN_MAX_IDLE_TIME=5m
EVENTHUB_REDIS_ADDR=localhost:6379
EVENTHUB_REDIS_USERNAME=
EVENTHUB_REDIS_PASSWORD=
EVENTHUB_REDIS_DB=0
EVENTHUB_REDIS_DIAL_TIMEOUT=5s
EVENTHUB_REDIS_READ_TIMEOUT=3s
EVENTHUB_REDIS_WRITE_TIMEOUT=3s
EVENTHUB_AUTH_TOKEN_ISSUER=eventhub-backend
EVENTHUB_ACCESS_TOKEN_SIGNING_SECRET=eventhub-dev-access-token-secret-for-local-development
EVENTHUB_ACCESS_TOKEN_TTL=30m
EVENTHUB_REFRESH_TOKEN_TTL=720h
