EVENTHUB_APP_NAME=eventhub-backend
EVENTHUB_ENV=prod
EVENTHUB_HTTP_PORT=8080
EVENTHUB_VERSION=prod
EVENTHUB_LOG_LEVEL=INFO
OPENAPI_ENABLED=false
EVENTHUB_MYSQL_DSN=eventhub:${EVENTHUB_MYSQL_PASSWORD}@tcp(mysql:3306)/eventhub?charset=utf8mb4&parseTime=true&loc=Local
EVENTHUB_MYSQL_MAX_OPEN_CONNS=20
EVENTHUB_MYSQL_MAX_IDLE_CONNS=5
EVENTHUB_MYSQL_CONN_MAX_LIFETIME=30m
EVENTHUB_MYSQL_CONN_MAX_IDLE_TIME=5m
EVENTHUB_AUTH_TOKEN_ISSUER=eventhub-backend
EVENTHUB_ACCESS_TOKEN_SIGNING_SECRET=
EVENTHUB_ACCESS_TOKEN_TTL=30m
EVENTHUB_REFRESH_TOKEN_TTL=720h
